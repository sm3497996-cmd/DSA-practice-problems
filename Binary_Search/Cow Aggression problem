#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int getDistance(vector<int> &arr, int N, int C)
{
    // N(logn)
    sort(arr.begin(), arr.end()); 

    int st = 1, end = arr[N - 1] - arr[0], ans = -1; // range
    while (st <= end)
    { // O(log(Range) *N)
        int mid = st + (end - st) / 2;
        if (isPossible(arr, N, C, mid))
        { 
            ans = mid;
            st = mid + 1;
        }
        else
        {
            end = mid - 1;
        }
    }
    return ans;
}
int main()
{
int N = 5, C = 3;
    vector<int> arr = {1, 2, 8, 4, 9};
    cout << getDistance(arr, N, C) << endl;
    return 0;
}
