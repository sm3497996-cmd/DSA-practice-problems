#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;
painters problem

bool ispossible(vector<int> arr, int n, int m, int maxAllowedtime)
{ // O(log(sum*n))
    int painters = 1, time = 0;
    for (int i = 0; i < n; i++)
    { // O(n)
        if (time + arr[i] <= maxAllowedtime)
        {
            time += arr[i];
        }
        else
        {
            painters++;
            time = arr[i];
        }
    }
    return painters <= m;
}

int minTimetoPaint(vector<int> &arr, int n, int m)
{
    int sum = 0, maxVal = INT_MIN; 
    for (int i = 0; i < n; i++)
    { // O(n)
        sum += arr[i];
        maxVal = max(maxVal, arr[i]);
    }

    int st = maxVal, end = sum, ans = -1;
    while (st <= end)
    { // log(sum)
        int mid = st + (end - st) / 2;
        if (ispossible(arr, n, m, mid))
        {
            ans = mid;
            end = mid - 1;
        }
        else
        {
            st = mid + 1;
        }
    }
    return ans;
}
