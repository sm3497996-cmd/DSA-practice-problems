class Solution {
public:

int digitSum(int n){
    if(n == 0){
            return 0;
        }

        int lastdigit = n%10;
        n = n/10;
        return lastdigit + digitSum(n);
}
    int addDigits(int n) {
        if (n<10){
        return n;
        }
        return addDigits(digitSum(n));
    }
};
