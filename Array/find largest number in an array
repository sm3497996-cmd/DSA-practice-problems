#include <iostream>
using namespace std;
int main()
{
int nums[] = {5, 7, 24, 12, 23};
    int size = 5;
    int largest = INT_MIN;
    int idx = 0;
    for (int i = 0; i < size; i++)
    {
        if (nums[i] > largest)
        {
            largest = nums[i];
            idx = i;
        }
    }

    cout << "largest = " << largest << endl;
    cout << idx << endl; 
    return 0;
    }
