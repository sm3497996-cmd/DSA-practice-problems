class Solution {
public:
    int findNumbers(vector<int>& nums) {
        int ans = 0;
        int n = nums.size();
        for(int i=0; i<n; i++){
             int num = nums[i];
            int digitcount = 0;
            while(num > 0){
                digitcount++;
                num /= 10;
            }
            if(digitcount %2 == 0){
               ans++;
            }
        }
        return ans;
    }
};
