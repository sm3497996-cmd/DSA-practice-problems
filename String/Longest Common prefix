class Solution {
public:
    string longestCommonPrefix(vector<string>& strs) {
        string st= "";
        for(int i=0; i<strs[0].size(); i++){
            for(int j=1; j<strs.size();j++){
                 if( i >= strs[j].size()){
               return st;
            }
                if(strs[0][i] != strs[j][i]){
                    return st;
                }
            }
            st += strs[0][i];
        }
        return st;
    }
};
